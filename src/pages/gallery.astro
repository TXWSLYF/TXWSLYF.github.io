---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

import galleryData from "@content/gallery/gallery.json";

type GalleryItem = {
  originalName: string;
  originalUrl: string;
  thumbnailUrl: string;
  width: number | null;
  height: number | null;
  mtimeMs?: number;
};

const items: GalleryItem[] = Array.isArray(galleryData?.items)
  ? galleryData.items
  : [];

items.sort((a, b) => (b.mtimeMs ?? 0) - (a.mtimeMs ?? 0));
---

<Layout title={`Gallery | ${SITE.title}`}>
  <Header activeNav="gallery" />

  <Main
    pageTitle="Gallery"
    pageDesc="A collection of everyday moments from my life."
    fullWidth={true}
  >
    <div
      id="gallery-lightgallery-root"
      class="mt-6 gap-3 [column-count:var(--gallery-columns)] lg:gap-4"
      style="--gallery-columns: 2;"
      aria-label="gallery"
    >
      {
        items.length === 0 ? (
          <p class="mt-6 italic opacity-70">
            当前还没有照片数据。请先运行本地的 `gallery:sync`
            命令生成配置并上传。
          </p>
        ) : (
          items.map(item => (
            <a
              class="mb-4 block break-inside-avoid cursor-pointer"
              href={item.originalUrl}
              data-thumb={item.thumbnailUrl}
              aria-label={item.originalName}
              title={item.originalName}
              data-sub-html={item.originalName}
            >
              <div
                class="relative w-full overflow-hidden"
                style={`aspect-ratio: ${
                  item.width && item.height
                    ? `${item.width} / ${item.height}`
                    : "1 / 1"
                }`}
              >
                <img
                  class="absolute inset-0 block h-full w-full object-cover"
                  src={item.thumbnailUrl}
                  alt={item.originalName}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </a>
          ))
        )
      }
    </div>
  </Main>

  <Footer />

  <script>
    import lightGallery from "lightgallery";
    import lgThumbnail from "lightgallery/plugins/thumbnail";
    import lgZoom from "lightgallery/plugins/zoom";
    import "lightgallery/css/lightgallery.css";
    import "lightgallery/css/lg-thumbnail.css";
    import "lightgallery/css/lg-zoom.css";

    function updateGalleryColumns(el: HTMLElement) {
      const minCardWidth = 320;
      const nextCount = Math.floor(el.clientWidth / minCardWidth);
      const clampedCount = Math.max(2, Math.min(5, nextCount));
      el.style.setProperty("--gallery-columns", String(clampedCount));
    }

    function initLightGallery() {
      const el = document.getElementById("gallery-lightgallery-root");
      if (!el) return;
      updateGalleryColumns(el);
      if (el.dataset.columnResizeBound !== "true") {
        window.addEventListener("resize", () => updateGalleryColumns(el));
        el.dataset.columnResizeBound = "true";
      }
      if (el.dataset.lgInitialized === "true") return;
      const links = el.querySelectorAll("a[data-sub-html]");
      if (links.length === 0) return;

      el.dataset.lgInitialized = "true";
      lightGallery(el, {
        plugins: [lgThumbnail, lgZoom],
        selector: "a[data-sub-html]",
        speed: 400,
        download: false,
        /* 底部缩略图条（官方 Thumbnail 插件） */
        thumbnail: true,
        animateThumb: true,
        currentPagerPosition: "middle",
        alignThumbnails: "middle",
        thumbWidth: 88,
        thumbHeight: "64px",
        thumbMargin: 6,
        enableThumbDrag: true,
        enableThumbSwipe: true,
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initLightGallery);
    } else {
      initLightGallery();
    }
  </script>
</Layout>
